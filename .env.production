APP_NAME=CodelessAI Smart Image Editor
APP_ENV=production
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=https://app.codelessai.com
API_PREFIX=/api
FRONTEND_URL=https://app.codelessai.com
STATIC_URL=/static
ALLOWED_ORIGINS=https://app.codelessai.com
ENABLE_HTTPS=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_TTL_MINUTES=480
MAX_UPLOAD_MB=20
MAX_IMAGE_DIMENSION=2048
MAX_CONCURRENT_JOBS=2
MODELS_DIR=/app/models
INTENT_MODEL_PATH=/app/models/Qwen2.5-3B-Instruct-GGUF.gguf
INTENT_MODEL_N_CTX=4096
INTENT_MODEL_N_THREADS=4
INTENT_MODEL_N_GPU_LAYERS=0
INTENT_MODEL_MAX_TOKENS=256
INTENT_MODEL_TEMPERATURE=0.0
INTENT_MODEL_TOP_P=0.95
